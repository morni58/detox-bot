# ============================================================
# 🌿 Detox Course — Environment Configuration
# ============================================================
# Скопируй этот файл: cp .env.example .env
# Заполни ВСЕ обязательные поля перед запуском
# ============================================================

# -------------------- Telegram Bot --------------------
# Получить у @BotFather → /newbot
BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLLmmNNoo

# ID администратора (число). Узнать: отправь /start боту @userinfobot
ADMIN_ID=123456789

# URL Mini App (будет открываться по кнопке в боте)
# Для разработки: https://localhost:5173
# Для продакшена: https://your-domain.com
WEBAPP_URL=https://your-domain.com

# -------------------- База данных (PostgreSQL) --------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=detox_course
POSTGRES_USER=detox_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Полный DSN (собирается автоматически в коде, но можно задать напрямую)
# DATABASE_URL=postgresql+asyncpg://detox_admin:password@postgres:5432/detox_course

# -------------------- Redis (кеширование + FSM) --------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -------------------- Оплата --------------------
# Telegram Payments (Stars) — провайдер-токен от @BotFather → /mybots → Payments
# Для тестовых платежей используй тестовый токен
PAYMENT_PROVIDER_TOKEN=TEST_PROVIDER_TOKEN

# Цена курса в Telegram Stars (1 Star ≈ $0.02)
COURSE_PRICE_STARS=1500

# Альтернатива: внешняя оплата (ЮKassa / Stripe)
# YUKASSA_SHOP_ID=
# YUKASSA_SECRET_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# -------------------- Mini App --------------------
# API URL для Mini App (бэкенд)
VITE_API_URL=https://your-domain.com/api

# Режим: development | production
VITE_MODE=production

# -------------------- Закрытый чат / канал --------------------
# Ссылка-инвайт в закрытый чат для купивших курс
PRIVATE_CHAT_INVITE_LINK=https://t.me/+XXXXXXXXXXXXX

# ID закрытого чата (для автоматического добавления)
PRIVATE_CHAT_ID=-1001234567890

# -------------------- Файловое хранилище --------------------
# Папка для загруженных фото (внутри контейнера)
UPLOAD_DIR=/app/uploads

# Максимальный размер файла (MB)
MAX_UPLOAD_SIZE_MB=10

# -------------------- Безопасность --------------------
# Секрет для подписи JWT / сессий (сгенерируй: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# CORS origins (через запятую)
CORS_ORIGINS=https://your-domain.com,https://web.telegram.org

# -------------------- Логирование --------------------
# Уровень: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Отправлять ошибки админу в Telegram (true/false)
NOTIFY_ADMIN_ON_ERROR=true

# -------------------- SSL / Домен (продакшен) --------------------
DOMAIN=your-domain.com
SSL_EMAIL=your-email@example.com

# -------------------- Docker --------------------
COMPOSE_PROJECT_NAME=detox-course
